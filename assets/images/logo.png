<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 100" width="400" height="100">
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#2563eb;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#7c3aed;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Briefcase icon -->
  <rect x="0" y="20" width="60" height="60" rx="12" fill="url(#grad)"/>
  <rect x="12" y="32" width="36" height="30" rx="6" fill="#ffffff" opacity="0.9"/>
  <rect x="18" y="38" width="24" height="16" rx="3" fill="url(#grad)"/>
  <rect x="22" y="42" width="16" height="8" rx="2" fill="#ffffff" opacity="0.5"/>
  
  <!-- Text: Loker -->
  <text x="80" y="47" font-family="Inter, Arial, sans-serif" font-size="40" font-weight="800" fill="#0f172a">
    Loker
  </text>
  
  <!-- Text: Kendari (gradient) -->
  <text x="195" y="47" font-family="Inter, Arial, sans-serif" font-size="40" font-weight="800" fill="url(#grad)">
    Kendari
  </text>
  
  <!-- Subtitle -->
  <text x="80" y="75" font-family="Inter, Arial, sans-serif" font-size="13" font-weight="500" fill="#64748b">
    Info Lowongan Kerja Terpercaya
  </text>
</svg>
